#!/usr/bin/env bash
# Sync current branch with remote base: fetch, merge, push.
# Usage: pr-sync [base]   or   pr-sync -b <base>
# Default base: PR_BASE_BRANCH env var, or master.

set -e

base="${PR_BASE_BRANCH:-master}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    -b|--base)
      base="$2"
      shift 2
      ;;
    *)
      base="$1"
      shift
      break
      ;;
  esac
done

git fetch origin "$base" && git merge FETCH_HEAD && git push
